<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:orientation="vertical" android:padding="16dp" android:layout_width="match_parent" android:layout_height="match_parent">
    <TextView android:id="@+id/tvTitle" android:text="Dashboard (placeholder)" android:textSize="18sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnStartVpn" android:text="Start VPN" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp"/>
    <Button android:id="@+id/btnStopVpn" android:text="Stop VPN" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
    <Button android:id="@+id/btnGoSettings" android:text="Go to Settings" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp"/>
    <TextView android:text="Proxy Server Testing (Carlos)" android:textSize="16sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp"/>
    <Button android:id="@+id/btnStartProxy" android:text="Start Proxy Server" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"/>
    <Button android:id="@+id/btnStopProxy" android:text="Stop Proxy Server" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:enabled="false"/>
</LinearLayout>