<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.shieldshare">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.TETHERING" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".ShieldShareApp"
        android:allowBackup="true"
        android:label="ShieldShare"
        android:theme="@style/Theme.ShieldShare">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".managers.vpn.VpnPermissionActivity"
            android:exported="false" />

        <service
            android:name=".managers.vpn.VpnTunnelService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:exported="false" />

        <service
            android:name=".managers.proxy.ProxyForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>
</manifest>
